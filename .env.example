# Core LLM configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_NAME=gpt-4o-mini

# Search / research tools
SERPER_API_KEY=your_serper_api_key

# Optional defaults
DEFAULT_LEAD_SCORE_THRESHOLD=70
ESTIMATED_INPUT_COST_PER_MILLION=0.150
ESTIMATED_OUTPUT_COST_PER_MILLION=0.600

# Optional app-level settings
LOG_LEVEL=INFO
